#include "divide-layouts.dtsi"
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &mock_kscan;
        zmk,matrix-transform = &default_transform;
        zmk,physical-layout = &default_layout;
    };

    mock_kscan: mock_kscan_0 {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        rows = <5>;
        columns = <12>;

        map = <
            /* Row 0: left 6 + right 8 */
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)
            RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(1,6)  RC(1,7)

            /* Row 1: left 6 + right 8 */
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)
            RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)

            /* Row 2: left 6 + right 7 */
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)
            RC(2,10) RC(2,11) RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10)

            /* Row 3: left 6 + right 6 */
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)
            RC(3,11) RC(4,6)  RC(4,7)  RC(4,8)  RC(4,9)  RC(4,10)

            /* Row 4: left 4 + right 1 */
            RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)
            RC(4,11)
        >;
    };
};


&default_layout {
    transform = <&default_transform>;
    kscan = <&mock_kscan>;
};
